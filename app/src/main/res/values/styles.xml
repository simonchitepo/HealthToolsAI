<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- =========================================================
         DIALOGS
         ========================================================= -->

    <style name="ThemeOverlay.Zealth.MaterialAlertDialog"
        parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="android:background">@drawable/bg_zealth_dialog</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.Zealth.DialogButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.Zealth.DialogButton</item>
    </style>

    <style name="Widget.Zealth.DialogButton"
        parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>

        <item name="backgroundTint">@color/zealth_surface_variant</item>
        <item name="strokeColor">@color/zealth_outline</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">14dp</item>

        <item name="android:textColor">@color/zealth_primary</item>

        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <!-- =========================================================
         DATE PICKER (UNIVERSAL READABILITY FIX)
         Use with MaterialDatePicker.Builder.datePicker().setTheme(...)
         ========================================================= -->

    <!-- Light / default (works even if device is in dark mode, keeping dates readable) -->
    <style name="ThemeOverlay.Zealth.DatePicker"
        parent="ThemeOverlay.MaterialComponents.MaterialCalendar">

        <!-- Accent / selection -->
        <item name="colorPrimary">@color/zealth_primary</item>
        <item name="colorOnPrimary">@android:color/white</item>

        <!-- Calendar surface + text (THIS fixes “white dates on white background”) -->
        <item name="colorSurface">@android:color/white</item>
        <item name="colorOnSurface">@color/zealth_on_surface</item>

    </style>

    <!-- =========================================================
         CARDS (Glass)
         ========================================================= -->

    <style name="Widget.Zealth.GlassCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">18dp</item>
        <item name="cardUseCompatPadding">false</item>
        <item name="cardElevation">10dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/glass_stroke</item>
        <item name="cardBackgroundColor">@color/glass_card_bg</item>
    </style>

    <style name="Widget.Zealth.GlassCard.Strong" parent="Widget.Zealth.GlassCard">
        <item name="cardBackgroundColor">@color/glass_card_bg_strong</item>
    </style>

    <!-- =========================================================
         BUTTONS
         ========================================================= -->

    <style name="Widget.Zealth.GlassButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="cornerRadius">16dp</item>
        <item name="strokeColor">@color/glass_stroke</item>
        <item name="strokeWidth">1dp</item>
        <item name="backgroundTint">@color/glass_sheet</item>

        <item name="android:textColor">@android:color/white</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>

        <item name="android:minHeight">48dp</item>

        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="Widget.Zealth.GlassPrimaryButton" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">16dp</item>
        <item name="backgroundTint">@color/zealth_primary_88</item>

        <item name="strokeColor">@color/glass_stroke</item>
        <item name="strokeWidth">1dp</item>

        <item name="android:textColor">@android:color/white</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>

        <item name="android:minHeight">56dp</item>

        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <!-- iOS-like segmented buttons (Metric / Imperial) -->
    <style name="Widget.Zealth.GlassSegmentButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>

        <item name="cornerRadius">14dp</item>

        <item name="backgroundTint">@color/zealth_segment_background</item>
        <item name="strokeColor">@color/zealth_segment_stroke</item>
        <item name="android:textColor">@color/zealth_segment_text</item>

        <item name="strokeWidth">1dp</item>
        <item name="android:minHeight">44dp</item>

        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <!-- Toggle button (used in pregnancy tracker, etc.) -->
    <style name="Widget.Zealth.ToggleButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="strokeColor">@color/zealth_outline</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">16dp</item>

        <item name="android:textColor">@color/zealth_primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>

        <item name="android:minHeight">44dp</item>

        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <!-- =========================================================
         TEXT INPUTS
         IMPORTANT: Provide BOTH names:
         - Widget.Zealth.TextField (legacy name referenced elsewhere)
         - Widget.Zealth.GlassTextField (new glass filled input)
         ========================================================= -->

    <!-- Legacy / widely referenced: outlined text field -->
    <style name="Widget.Zealth.TextField"
        parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>

        <item name="boxStrokeColor">@color/zealth_outline</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>

        <item name="boxBackgroundColor">@color/zealth_surface_88</item>

        <item name="hintTextColor">@color/zealth_on_surface_variant</item>

        <item name="startIconTint">@color/zealth_primary</item>
        <item name="endIconTint">@color/zealth_primary</item>
    </style>

    <style name="Widget.Zealth.TextInputEditText"
        parent="Widget.MaterialComponents.TextInputEditText.OutlinedBox">
        <item name="android:textColor">@color/zealth_on_surface</item>
        <item name="android:textColorHint">@color/zealth_on_surface_variant</item>
        <item name="android:textSize">14sp</item>
    </style>

    <!-- Glass filled text field (for BMI glass screens) -->
    <style name="Widget.Zealth.GlassTextField"
        parent="Widget.MaterialComponents.TextInputLayout.FilledBox">
        <item name="boxBackgroundMode">filled</item>
        <item name="boxBackgroundColor">@color/glass_sheet_strong</item>
        <item name="boxStrokeColor">@color/glass_stroke</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>

        <item name="hintTextColor">@color/glass_hint</item>

        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
    </style>

    <style name="Widget.Zealth.GlassTextInputEditText"
        parent="Widget.MaterialComponents.TextInputEditText.FilledBox">
        <item name="android:textColor">@android:color/black</item>
        <item name="android:textColorHint">@android:color/darker_gray</item>
        <item name="android:textSize">14sp</item>
    </style>

    <!-- =========================================================
         LEGACY COMPAT WRAPPERS (fix sheet_details.xml)
         ========================================================= -->

    <!-- Old name used by some layouts -->
    <style name="GlassButton" parent="Widget.Zealth.GlassButton" />

    <!-- Old name used by some layouts -->
    <style name="GlassButtonPrimary" parent="Widget.Zealth.GlassPrimaryButton" />

    <style name="ZealthDropDownItem">
        <item name="android:textColor">#111827</item>
        <item name="android:textSize">16sp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
    </style>
    <style name="Widget.Zealth.FilterChip" parent="Widget.MaterialComponents.Chip.Choice">
        <!-- Shape / sizing -->
        <item name="chipCornerRadius">18dp</item>
        <item name="chipMinHeight">36dp</item>
        <item name="android:minHeight">36dp</item>

        <!-- Colors -->
        <item name="chipBackgroundColor">@color/chip_bg_selector</item>
        <item name="android:textColor">@color/chip_text_selector</item>
        <item name="chipStrokeColor">@color/chip_stroke_selector</item>
        <item name="chipStrokeWidth">1dp</item>

        <!-- Ripple -->
        <item name="rippleColor">@color/zealth_divider</item>

        <!-- Checked icon -->
        <item name="checkedIconVisible">true</item>
        <item name="checkedIconTint">@color/zealth_on_primary</item>

        <!-- Spacing -->
        <item name="chipStartPadding">12dp</item>
        <item name="chipEndPadding">12dp</item>
        <item name="textStartPadding">6dp</item>
        <item name="textEndPadding">6dp</item>
    </style>
    <style name="ThemeOverlay.Zealth.PregnancyDatePicker"
        parent="ThemeOverlay.MaterialComponents.MaterialCalendar">

        <!-- Match your pregnancy palette -->
        <item name="colorPrimary">#DB2777</item>      <!-- C_ACCENT -->
        <item name="colorOnPrimary">#FFFFFF</item>

        <item name="colorSurface">#FFFFFF</item>      <!-- C_SHEET -->
        <item name="colorOnSurface">#2A1B2E</item>    <!-- C_TEXT -->
        <item name="colorOnSurfaceVariant">#6B4E6B</item> <!-- C_MUTED -->
    </style>


</resources>
