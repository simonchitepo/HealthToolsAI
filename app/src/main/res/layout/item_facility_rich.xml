<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="10dp"
    app:cardBackgroundColor="#22FFFFFF"
    app:strokeWidth="1dp"
    app:strokeColor="#22FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Hospital name"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpenMap"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text=""
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"
                app:cornerRadius="14dp"
                android:backgroundTint="#22FFFFFF"
                app:icon="@android:drawable/ic_menu_mapmode"
                app:iconTint="@android:color/white"
                app:iconSize="20dp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hospital • 2.4km"
            android:textColor="#DFFFFFFF"
            android:textSize="13sp"
            android:layout_marginTop="6dp"/>

        <TextView
            android:id="@+id/tvAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Address"
            android:textColor="#BFFFFFFF"
            android:textSize="12sp"
            android:layout_marginTop="6dp"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/tvPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Phone"
            android:textColor="#BFFFFFFF"
            android:textSize="12sp"
            android:layout_marginTop="2dp"
            android:visibility="gone"/>

        <!-- Readiness indexes -->
        <LinearLayout
            android:id="@+id/readinessBlock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Facility readiness"
                android:textColor="#EFFFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvCapacity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Capacity: Unknown"
                android:textColor="#DFFFFFFF"
                android:textSize="12sp"/>

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progEquipment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                app:trackThickness="6dp"/>

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progStock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                app:trackThickness="6dp"/>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipsDrugs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:visibility="gone"
                app:singleLine="true"/>
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
