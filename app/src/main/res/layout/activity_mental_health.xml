<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#121212">

    <!-- Spotify-like top wash -->
    <View
        android:layout_width="match_parent"
        android:layout_height="260dp"
        android:background="@drawable/bg_spotify_header" />

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:fitsSystemWindows="true"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            app:title="Mood &amp; Journal"
            app:subtitle="Check-ins, journaling, and trends"
            app:titleTextColor="#FFFFFF"
            app:subtitleTextColor="#B3B3B3"
            app:navigationIcon="@drawable/ic_back_medical"
            app:navigationIconTint="#FFFFFF" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="18dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp">

            <!-- Urgent help / Disclaimer -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDisclaimer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#181818"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeColor="#2A2A2A"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Important"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Zealth supports self-tracking and journaling for general well-being. It does not provide medical, mental health, diagnostic, treatment, or emergency services. If you are in immediate danger or need urgent help, contact local emergency services now."
                        android:textColor="#B3B3B3"
                        android:textSize="13sp"
                        android:lineSpacingExtra="2dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEmergencyHelp"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="12dp"
                        android:text="Get urgent help options"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        android:textColor="#0B0B0B"
                        app:backgroundTint="#1DB954"
                        app:cornerRadius="999dp"
                        app:rippleColor="#33FFFFFF" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Mood -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMood"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#181818"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeColor="#2A2A2A"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Mood check-in"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/tvMoodValue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Mood: 3 / 5  •  Neutral"
                        android:textColor="#B3B3B3"
                        android:textSize="13sp" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderMood"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        app:labelBehavior="withinBounds"
                        app:thumbColor="#1DB954"
                        app:haloColor="#331DB954"
                        app:trackColorActive="#1DB954"
                        app:trackColorInactive="#3A3A3A" />

                    <!-- Emoji row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/emoji1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="😞"
                            android:textSize="22sp"
                            android:alpha="0.55"
                            android:textColor="#B3B3B3" />

                        <TextView
                            android:id="@+id/emoji2"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="😕"
                            android:textSize="22sp"
                            android:alpha="0.55"
                            android:textColor="#B3B3B3" />

                        <TextView
                            android:id="@+id/emoji3"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="😐"
                            android:textSize="22sp"
                            android:textColor="#FFFFFF" />

                        <TextView
                            android:id="@+id/emoji4"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="🙂"
                            android:textSize="22sp"
                            android:alpha="0.55"
                            android:textColor="#B3B3B3" />

                        <TextView
                            android:id="@+id/emoji5"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="😁"
                            android:textSize="22sp"
                            android:alpha="0.55"
                            android:textColor="#B3B3B3" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Tags (optional)"
                        android:textColor="#B3B3B3"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupTags"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:singleSelection="false"
                        app:chipSpacingHorizontal="8dp"
                        app:chipSpacingVertical="8dp">

                        <com.google.android.material.chip.Chip
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Stress"
                            android:checkable="true"
                            android:textColor="#FFFFFF"
                            app:chipBackgroundColor="#262626"
                            app:chipStrokeColor="#3A3A3A"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sleep"
                            android:checkable="true"
                            android:textColor="#FFFFFF"
                            app:chipBackgroundColor="#262626"
                            app:chipStrokeColor="#3A3A3A"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Work"
                            android:checkable="true"
                            android:textColor="#FFFFFF"
                            app:chipBackgroundColor="#262626"
                            app:chipStrokeColor="#3A3A3A"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Family"
                            android:checkable="true"
                            android:textColor="#FFFFFF"
                            app:chipBackgroundColor="#262626"
                            app:chipStrokeColor="#3A3A3A"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Anxiety"
                            android:checkable="true"
                            android:textColor="#FFFFFF"
                            app:chipBackgroundColor="#262626"
                            app:chipStrokeColor="#3A3A3A"
                            app:chipStrokeWidth="1dp" />
                    </com.google.android.material.chip.ChipGroup>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Optional note (what influenced your mood?)"
                        app:boxBackgroundMode="filled"
                        app:boxBackgroundColor="#1F1F1F"
                        app:boxCornerRadiusTopStart="14dp"
                        app:boxCornerRadiusTopEnd="14dp"
                        app:boxCornerRadiusBottomStart="14dp"
                        app:boxCornerRadiusBottomEnd="14dp"
                        app:boxStrokeColor="#3A3A3A"
                        app:hintTextColor="#B3B3B3">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etMoodNote"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minLines="2"
                            android:gravity="top"
                            android:inputType="textMultiLine"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#777777" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSaveMood"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="12dp"
                        android:text="Save check-in"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        android:textColor="#0B0B0B"
                        app:backgroundTint="#1DB954"
                        app:cornerRadius="999dp"
                        app:rippleColor="#33FFFFFF" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Journal -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardJournal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#181818"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeColor="#2A2A2A"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Journal"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/tvPrompt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Prompt: What’s one thing you can influence today?"
                        android:textColor="#B3B3B3"
                        android:textSize="13sp"
                        android:lineSpacingExtra="2dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnNewPrompt"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="10dp"
                        android:text="New prompt"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        app:backgroundTint="#262626"
                        app:cornerRadius="999dp"
                        app:rippleColor="#22FFFFFF" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Write a journal entry (private)"
                        app:boxBackgroundMode="filled"
                        app:boxBackgroundColor="#1F1F1F"
                        app:boxCornerRadiusTopStart="14dp"
                        app:boxCornerRadiusTopEnd="14dp"
                        app:boxCornerRadiusBottomStart="14dp"
                        app:boxCornerRadiusBottomEnd="14dp"
                        app:boxStrokeColor="#3A3A3A"
                        app:hintTextColor="#B3B3B3">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etJournal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minLines="4"
                            android:gravity="top"
                            android:inputType="textMultiLine"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#777777" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSaveJournal"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="12dp"
                        android:text="Save journal entry"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        android:textColor="#0B0B0B"
                        app:backgroundTint="#1DB954"
                        app:cornerRadius="999dp"
                        app:rippleColor="#33FFFFFF" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Insights -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardInsights"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#181818"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeColor="#2A2A2A"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Insights"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerWeek"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never" />

                    <com.cypher.zealth.SparklineView
                        android:id="@+id/sparkline"
                        android:layout_width="match_parent"
                        android:layout_height="90dp"
                        android:layout_marginTop="10dp"
                        android:background="#1F1F1F" />

                    <TextView
                        android:id="@+id/tvAvg7"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="7-day avg mood: —"
                        android:textColor="#B3B3B3"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvStreak"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Streak: —"
                        android:textColor="#B3B3B3"
                        android:textSize="13sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Top tags this week"
                        android:textStyle="bold"
                        android:textColor="#B3B3B3"
                        android:textSize="13sp" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipTopTags"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:chipSpacingHorizontal="8dp"
                        app:chipSpacingVertical="8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Settings -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSettings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#181818"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeColor="#2A2A2A"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Settings"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/swHidePreviews"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Hide previews in history"
                        android:textColor="#B3B3B3" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/swAppLock"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="App lock (biometric / device PIN)"
                        android:textColor="#B3B3B3" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="12dp"
                        android:background="#2A2A2A" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/swMoodReminders"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Check-in reminders"
                        android:textColor="#B3B3B3" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnReminderTime"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="10dp"
                        android:text="Reminder time: 20:00"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        app:backgroundTint="#262626"
                        app:cornerRadius="999dp"
                        app:rippleColor="#22FFFFFF" />

                    <TextView
                        android:id="@+id/tvReminderHint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="If reminders don’t fire reliably, allow exact alarms in system settings."
                        android:textColor="#B3B3B3"
                        android:textSize="12sp"
                        android:lineSpacingExtra="2dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="12dp"
                        android:background="#2A2A2A" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnExport"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Export PDF"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        app:backgroundTint="#262626"
                        app:cornerRadius="999dp"
                        app:rippleColor="#22FFFFFF" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnImport"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="10dp"
                        android:text="Import PDF"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        app:backgroundTint="#262626"
                        app:cornerRadius="999dp"
                        app:rippleColor="#22FFFFFF" />


                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- History -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#181818"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeColor="#2A2A2A"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="History"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp" />

                    <com.google.android.material.chip.ChipGroup
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        app:singleSelection="true"
                        app:selectionRequired="true"
                        app:chipSpacingHorizontal="8dp"
                        app:chipSpacingVertical="8dp">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipFilterAll"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="All"
                            android:checkable="true"
                            android:checked="true"
                            android:textColor="#FFFFFF"
                            app:chipBackgroundColor="#262626"
                            app:chipStrokeColor="#3A3A3A"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipFilterMood"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mood"
                            android:checkable="true"
                            android:textColor="#FFFFFF"
                            app:chipBackgroundColor="#262626"
                            app:chipStrokeColor="#3A3A3A"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipFilterJournal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Journal"
                            android:checkable="true"
                            android:textColor="#FFFFFF"
                            app:chipBackgroundColor="#262626"
                            app:chipStrokeColor="#3A3A3A"
                            app:chipStrokeWidth="1dp" />
                    </com.google.android.material.chip.ChipGroup>

                    <LinearLayout
                        android:id="@+id/emptyState"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="vertical"
                        android:padding="14dp"
                        android:background="#1F1F1F"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="No entries yet"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Start with a quick mood check-in or write a short journal entry."
                            android:textColor="#B3B3B3"
                            android:textSize="13sp"
                            android:lineSpacingExtra="2dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnEmptyGoMood"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="10dp"
                            android:text="Start a mood check-in"
                            android:textAllCaps="false"
                            android:textStyle="bold"
                            android:textColor="#0B0B0B"
                            app:backgroundTint="#1DB954"
                            app:cornerRadius="999dp"
                            app:rippleColor="#33FFFFFF" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnEmptyGoJournal"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="10dp"
                            android:text="Write your first journal entry"
                            android:textAllCaps="false"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            app:backgroundTint="#262626"
                            app:cornerRadius="999dp"
                            app:rippleColor="#22FFFFFF" />
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerHistory"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:nestedScrollingEnabled="false"
                        android:clipToPadding="false" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnClearHistory"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="12dp"
                        android:text="Clear history"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        app:backgroundTint="#262626"
                        app:cornerRadius="999dp"
                        app:rippleColor="#22FFFFFF" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <View
                android:layout_width="match_parent"
                android:layout_height="18dp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
