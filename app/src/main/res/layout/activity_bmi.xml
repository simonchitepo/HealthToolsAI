<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#F6FAFF">

    <!-- Clean gradient background (visual-only) -->
    <View
        android:id="@+id/bgGradient"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_bmi_gradient" />

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/contentRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Optional safe-area spacer for status bar -->
        <View
            android:id="@+id/statusBarSpacer"
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:layout_gravity="top"
            android:background="@android:color/transparent" />

        <!-- Top "sheet" (toolbar container) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/toolbarCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="24dp"
            app:cardElevation="10dp"
            app:cardUseCompatPadding="true"
            app:strokeColor="#D6E6FF"
            app:strokeWidth="1dp">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                app:title="BMI Calculator"
                app:subtitle="General information for personal reference"
                app:titleTextColor="#0B1B3A"
                app:subtitleTextColor="#3A6BB8"
                app:navigationIcon="@drawable/ic_back_medical"
                app:navigationIconTint="#2563EB" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Content -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/scroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="94dp"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:overScrollMode="never"
            android:paddingStart="16dp"
            android:paddingTop="12dp"
            android:paddingEnd="16dp"
            android:paddingBottom="116dp"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Segmented control container -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="10dp"
                    app:cardUseCompatPadding="true"
                    app:strokeColor="#D6E6FF"
                    app:strokeWidth="1dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="10dp">

                        <eightbitlab.com.blurview.BlurView
                            android:id="@+id/blurSegment"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@android:color/transparent"
                            android:minHeight="60dp" />

                        <com.google.android.material.button.MaterialButtonToggleGroup
                            android:id="@+id/unitToggle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:selectionRequired="true"
                            app:singleSelection="true">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnMetric"
                                style="?attr/materialButtonOutlinedStyle"
                                android:layout_width="0dp"
                                android:layout_height="46dp"
                                android:layout_weight="1"
                                android:checked="true"
                                android:text="Metric"
                                android:textAllCaps="false"
                                android:textColor="#0B1B3A"
                                android:textStyle="bold"
                                app:backgroundTint="#EAF2FF"
                                app:cornerRadius="16dp"
                                app:strokeColor="#93C5FD"
                                app:strokeWidth="1dp"
                                app:rippleColor="#223B82F6" />

                            <Space
                                android:layout_width="10dp"
                                android:layout_height="1dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnImperial"
                                style="?attr/materialButtonOutlinedStyle"
                                android:layout_width="0dp"
                                android:layout_height="46dp"
                                android:layout_weight="1"
                                android:text="Imperial"
                                android:textAllCaps="false"
                                android:textColor="#2B5AA6"
                                android:textStyle="bold"
                                app:backgroundTint="#F4F8FF"
                                app:cornerRadius="16dp"
                                app:strokeColor="#D6E6FF"
                                app:strokeWidth="1dp"
                                app:rippleColor="#2293C5FD" />
                        </com.google.android.material.button.MaterialButtonToggleGroup>

                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Metric inputs -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/groupMetric"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="10dp"
                    app:cardUseCompatPadding="true"
                    app:strokeColor="#D6E6FF"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp"
                            android:text="Height"
                            android:textColor="#2B5AA6"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilHeightCm"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:boxBackgroundColor="#F7FBFF"
                            app:boxBackgroundMode="outline"
                            app:boxCornerRadiusTopStart="18dp"
                            app:boxCornerRadiusTopEnd="18dp"
                            app:boxCornerRadiusBottomStart="18dp"
                            app:boxCornerRadiusBottomEnd="18dp"
                            app:boxStrokeColor="#93C5FD"
                            app:boxStrokeWidth="1dp"
                            app:boxStrokeWidthFocused="2dp"
                            app:hintTextColor="#3B82F6">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etHeightCm"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@android:color/transparent"
                                android:hint="Your height (cm)"
                                android:imeOptions="actionNext"
                                android:inputType="numberDecimal"
                                android:paddingStart="14dp"
                                android:paddingTop="14dp"
                                android:paddingEnd="14dp"
                                android:paddingBottom="14dp"
                                android:textColor="#0B1B3A"
                                android:textColorHint="#7AA7E8" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:layout_marginBottom="6dp"
                            android:text="Weight"
                            android:textColor="#2B5AA6"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilWeightKg"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:boxBackgroundColor="#F7FBFF"
                            app:boxBackgroundMode="outline"
                            app:boxCornerRadiusTopStart="18dp"
                            app:boxCornerRadiusTopEnd="18dp"
                            app:boxCornerRadiusBottomStart="18dp"
                            app:boxCornerRadiusBottomEnd="18dp"
                            app:boxStrokeColor="#60A5FA"
                            app:boxStrokeWidth="1dp"
                            app:boxStrokeWidthFocused="2dp"
                            app:hintTextColor="#2563EB">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etWeightKg"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@android:color/transparent"
                                android:hint="Your weight (kg)"
                                android:imeOptions="actionDone"
                                android:inputType="numberDecimal"
                                android:paddingStart="14dp"
                                android:paddingTop="14dp"
                                android:paddingEnd="14dp"
                                android:paddingBottom="14dp"
                                android:textColor="#0B1B3A"
                                android:textColorHint="#7AA7E8" />
                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Imperial inputs -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/groupImperial"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="10dp"
                    app:cardUseCompatPadding="true"
                    app:strokeColor="#D6E6FF"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp"
                            android:text="Height"
                            android:textColor="#2B5AA6"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/tilHeightFt"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                app:boxBackgroundColor="#F7FBFF"
                                app:boxBackgroundMode="outline"
                                app:boxCornerRadiusTopStart="18dp"
                                app:boxCornerRadiusTopEnd="18dp"
                                app:boxCornerRadiusBottomStart="18dp"
                                app:boxCornerRadiusBottomEnd="18dp"
                                app:boxStrokeColor="#93C5FD"
                                app:boxStrokeWidth="1dp"
                                app:boxStrokeWidthFocused="2dp">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etHeightFt"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:background="@android:color/transparent"
                                    android:hint="ft"
                                    android:imeOptions="actionNext"
                                    android:inputType="number"
                                    android:paddingStart="14dp"
                                    android:paddingTop="14dp"
                                    android:paddingEnd="14dp"
                                    android:paddingBottom="14dp"
                                    android:textColor="#0B1B3A"
                                    android:textColorHint="#7AA7E8" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <Space
                                android:layout_width="10dp"
                                android:layout_height="1dp" />

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/tilHeightIn"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                app:boxBackgroundColor="#F7FBFF"
                                app:boxBackgroundMode="outline"
                                app:boxCornerRadiusTopStart="18dp"
                                app:boxCornerRadiusTopEnd="18dp"
                                app:boxCornerRadiusBottomStart="18dp"
                                app:boxCornerRadiusBottomEnd="18dp"
                                app:boxStrokeColor="#93C5FD"
                                app:boxStrokeWidth="1dp"
                                app:boxStrokeWidthFocused="2dp">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etHeightIn"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:background="@android:color/transparent"
                                    android:hint="in"
                                    android:imeOptions="actionNext"
                                    android:inputType="number"
                                    android:paddingStart="14dp"
                                    android:paddingTop="14dp"
                                    android:paddingEnd="14dp"
                                    android:paddingBottom="14dp"
                                    android:textColor="#0B1B3A"
                                    android:textColorHint="#7AA7E8" />
                            </com.google.android.material.textfield.TextInputLayout>

                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:layout_marginBottom="6dp"
                            android:text="Weight"
                            android:textColor="#2B5AA6"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilWeightLb"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:boxBackgroundColor="#F7FBFF"
                            app:boxBackgroundMode="outline"
                            app:boxCornerRadiusTopStart="18dp"
                            app:boxCornerRadiusTopEnd="18dp"
                            app:boxCornerRadiusBottomStart="18dp"
                            app:boxCornerRadiusBottomEnd="18dp"
                            app:boxStrokeColor="#60A5FA"
                            app:boxStrokeWidth="1dp"
                            app:boxStrokeWidthFocused="2dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etWeightLb"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@android:color/transparent"
                                android:hint="Your weight (lb)"
                                android:imeOptions="actionDone"
                                android:inputType="numberDecimal"
                                android:paddingStart="14dp"
                                android:paddingTop="14dp"
                                android:paddingEnd="14dp"
                                android:paddingBottom="14dp"
                                android:textColor="#0B1B3A"
                                android:textColorHint="#7AA7E8" />
                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- RESULTS: stacked cards -->
                <LinearLayout
                    android:id="@+id/resultStack"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <!-- HERO SUMMARY CARD -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/resultHeroCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="28dp"
                        app:cardElevation="12dp"
                        app:cardUseCompatPadding="true"
                        app:strokeColor="#D6E6FF"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_card_glass"
                            android:orientation="vertical"
                            android:padding="18dp">

                            <TextView
                                android:id="@+id/tvHeroTitle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Your BMI"
                                android:textColor="#2B5AA6"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/tvBmiValue"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="—"
                                    android:textColor="#0B1B3A"
                                    android:textSize="34sp"
                                    android:textStyle="bold" />

                                <com.google.android.material.chip.Chip
                                    android:id="@+id/chipCategory"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background="@android:color/transparent"
                                    android:checkable="false"
                                    android:clickable="false"
                                    android:minHeight="34dp"
                                    android:text="—"
                                    android:textStyle="bold"
                                    android:textColor="#1D4ED8"
                                    app:chipBackgroundColor="#DBEAFE"
                                    app:chipCornerRadius="999dp" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvBmiCategory"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="—"
                                android:textColor="#2563EB"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <com.cypher.zealth.views.BmiComparisonChartView
                                android:id="@+id/bmiChart"
                                android:layout_width="match_parent"
                                android:layout_height="96dp"
                                android:layout_marginTop="12dp" />

                            <TextView
                                android:id="@+id/tvGlobalCompare"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="—"
                                android:textColor="#2B5AA6"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/tvHealthyRange"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="—"
                                android:textColor="#2B5AA6"
                                android:textSize="13sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- INFORMATION CARD (rename from Guidance) -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/guidanceCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="10dp"
                        app:cardUseCompatPadding="true"
                        app:strokeColor="#D6E6FF"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_card_surface"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:id="@+id/tvGuidanceTitle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Information"
                                android:textColor="#0B1B3A"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvGuidance"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:lineSpacingExtra="2dp"
                                android:text="—"
                                android:textColor="#0B1B3A"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/tvDisclaimerSmall"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="Disclaimer: For general informational purposes only. Not a medical device. Does not diagnose or treat. Consult a qualified professional for medical advice."
                                android:textColor="#64748B"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- OPTIONAL ESTIMATES CARD (rename from Plan) -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/planCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="10dp"
                        app:cardUseCompatPadding="true"
                        app:strokeColor="#D6E6FF"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_card_surface"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:id="@+id/tvPlanTitle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Optional estimates"
                                android:textColor="#0B1B3A"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <!-- Row: Reference -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:background="@drawable/bg_row_tint_blue"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:padding="12dp">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Reference"
                                    android:textColor="#0B1B3A"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                                <!-- keep ids for backward compatibility; you can repurpose text in code -->
                                <TextView
                                    android:id="@+id/tvPlanTarget"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="—"
                                    android:textColor="#1D4ED8"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <!-- Row: Notes -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:background="@drawable/bg_row_tint_blue"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:padding="12dp">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Notes"
                                    android:textColor="#0B1B3A"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tvPlanPace"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="—"
                                    android:textColor="#1D4ED8"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <!-- Row: Variability -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:background="@drawable/bg_row_tint_blue"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:padding="12dp">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Variability"
                                    android:textColor="#0B1B3A"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tvPlanTime"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="—"
                                    android:textColor="#1D4ED8"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <!-- Divider -->
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:layout_marginTop="14dp"
                                android:background="#E6F0FF" />

                            <!-- Estimates block (rename from Calories) -->
                            <TextView
                                android:id="@+id/tvCaloriesTitle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="14dp"
                                android:text="General estimates"
                                android:textColor="#0B1B3A"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvCaloriesBody"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="—"
                                android:textColor="#2B5AA6"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/tvPlanDisclaimer"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="These values are generalized estimates and may vary by individual. They are not medical advice."
                                android:textColor="#64748B"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="18dp" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- Bottom CTA -->
    <FrameLayout
        android:id="@+id/bottomCta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">

        <eightbitlab.com.blurview.BlurView
            android:id="@+id/blurButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@android:color/transparent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCalculate"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:elevation="0dp"
            android:text="Calculate"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:backgroundTint="#2563EB"
            app:cornerRadius="999dp"
            app:rippleColor="#22FFFFFF"
            app:strokeColor="#93C5FD"
            app:strokeWidth="1dp" />
    </FrameLayout>

</FrameLayout>
