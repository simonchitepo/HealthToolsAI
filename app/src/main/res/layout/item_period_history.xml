<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/zealth_outline"
    app:cardBackgroundColor="@color/zealth_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvHistoryTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Period: 2025-01-01 → Ongoing"
            android:textStyle="bold"
            android:textColor="@color/zealth_on_surface"
            android:textSize="14sp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEndPeriod"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                android:text="End period"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="@color/zealth_primary"
                android:backgroundTint="@android:color/transparent"
                app:cornerRadius="16dp"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/zealth_outline"/>

            <View
                android:layout_width="10dp"
                android:layout_height="1dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeleteEntry"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                android:text="Delete"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="@color/zealth_primary"
                android:backgroundTint="@android:color/transparent"
                app:cornerRadius="16dp"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/zealth_outline"/>
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
