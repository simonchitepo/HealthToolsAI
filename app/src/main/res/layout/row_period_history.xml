<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="6dp"
    app:cardUseCompatPadding="true"
    app:strokeWidth="1dp"
    app:strokeColor="#22A855F7"
    app:cardBackgroundColor="#FFFFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvRowTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start: —"
            android:textStyle="bold"
            android:textColor="#24113D"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/tvRowSub"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="End: —"
            android:textColor="#3B2A54"
            android:textSize="13sp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRowEnd"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="End period"
                android:textAllCaps="false"
                android:textStyle="bold"
                app:cornerRadius="999dp"
                app:backgroundTint="#F3E8FF"
                app:strokeColor="#C4B5FD"
                app:strokeWidth="1dp"
                android:textColor="#6D28D9"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"/>

            <Space
                android:layout_width="10dp"
                android:layout_height="1dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRowDelete"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="Delete"
                android:textAllCaps="false"
                android:textStyle="bold"
                app:cornerRadius="999dp"
                app:backgroundTint="#FFE4E6"
                app:strokeColor="#FDA4AF"
                app:strokeWidth="1dp"
                android:textColor="#9F1239"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"/>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
