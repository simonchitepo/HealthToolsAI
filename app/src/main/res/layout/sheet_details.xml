<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/sheetRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:cardCornerRadius="26dp"
    app:cardElevation="12dp"
    app:cardBackgroundColor="@color/glass_sheet"
    app:strokeWidth="1dp"
    app:strokeColor="@color/glass_stroke"
    android:layout_marginTop="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:layout_width="44dp"
                android:layout_height="5dp"
                android:layout_gravity="center"
                android:background="@drawable/sheet_handle"
                android:layout_weight="1"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/sheetClose"
                style="@style/GlassButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Close"/>
        </LinearLayout>

        <TextView
            android:id="@+id/sheetTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Details"
            android:textColor="@color/zealth_on_surface"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/sheetSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Provider info and actions."
            android:textColor="@color/zealth_on_surface_variant"
            android:textSize="13sp"/>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/sheetContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Add cards/sections dynamically or via include -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/glass_card_inner"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/glass_stroke">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Snapshot"
                            android:textStyle="bold"
                            android:textColor="@color/zealth_on_surface"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Add your details here..."
                            android:textColor="@color/zealth_on_surface_variant"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/sheetPrimary"
                style="@style/GlassButtonPrimary"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                android:text="Call"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/sheetSecondary"
                style="@style/GlassButton"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:text="Directions"/>
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
