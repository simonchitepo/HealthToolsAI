<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background image -->
    <ImageView
        android:id="@+id/imgSplashBg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/splash_bg"
        android:scaleType="centerCrop"
        android:contentDescription="@null" />

    <!-- Optional dark overlay for readability -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#33000000" />

    <!-- Foreground content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvSplashTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Health Tools AI: Doctor and Map"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textColor="@android:color/white" />

        <TextView
            android:id="@+id/tvSplashSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Loading your health tools…"
            android:textSize="14sp"
            android:textColor="#CCFFFFFF" />

        <!-- Spacer pushes loading bar towards bottom -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Real loading bar -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progressSplash"
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:layout_marginBottom="18dp"
            app:trackCornerRadius="999dp"
            app:indicatorTrackGapSize="0dp"
            app:trackColor="#55FFFFFF"
            app:indicatorColor="@color/zealth_primary"
            android:max="100"
            android:progress="0"
            android:indeterminate="false" />
    </LinearLayout>

</FrameLayout>
