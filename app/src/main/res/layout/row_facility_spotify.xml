<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="#181818"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="#2A2A2A"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:id="@+id/iconDot"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginEnd="10dp"
                android:background="#1DB954" />

            <TextView
                android:id="@+id/facilityName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Facility name"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/facilityPill"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HOSPITAL"
                android:textColor="#000000"
                android:textStyle="bold"
                android:textSize="11sp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:background="#1DB954"/>
        </LinearLayout>

        <TextView
            android:id="@+id/facilitySubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="0.8km • Address"
            android:textColor="#B3B3B3"
            android:textSize="13sp"
            android:maxLines="2"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/facilityMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Phone • Web • Email"
            android:textColor="#8A8A8A"
            android:textSize="12sp"
            android:maxLines="2"
            android:ellipsize="end"/>

        <!-- Actions row (icon-only, Spotify-like minimal) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/actionMap"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_dialog_map"
                android:tint="#B3B3B3" />

            <ImageView
                android:id="@+id/actionNav"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="10dp"
                android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_compass"
                android:tint="#B3B3B3" />

            <ImageView
                android:id="@+id/actionCall"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="10dp"
                android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_call"
                android:tint="#B3B3B3" />

            <ImageView
                android:id="@+id/actionWeb"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="10dp"
                android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_view"
                android:tint="#B3B3B3" />

            <ImageView
                android:id="@+id/actionEmail"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="10dp"
                android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_dialog_email"
                android:tint="#B3B3B3" />
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
