<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootSheet"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="18dp"
    android:paddingEnd="18dp"
    android:paddingTop="16dp"
    android:paddingBottom="18dp"
    android:background="#121212">

    <TextView
        android:id="@+id/tvSheetTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Emergency help"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvSheetSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Region: --  •  Emergency: --"
        android:textColor="#B3B3B3"
        android:textSize="13sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPrimaryCall"
        style="@style/Widget.MaterialComponents.Button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="Call emergency"
        android:textAllCaps="false"
        android:textColor="#000000"
        app:backgroundTint="#1DB954"
        app:cornerRadius="999dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnMoreOnline"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="More local crisis resources (online)"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        app:cornerRadius="999dp"
        app:strokeColor="#2A2A2A"
        app:strokeWidth="1dp" />

    <TextView
        android:id="@+id/tvSheetHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="If you feel unsafe or may harm yourself or others, seek urgent help now."
        android:textColor="#B3B3B3"
        android:textSize="12sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerEmergency"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:overScrollMode="never" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnClose"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Close"
        android:textAllCaps="false"
        android:textColor="#B3B3B3"
        app:cornerRadius="999dp"
        app:strokeColor="#2A2A2A"
        app:strokeWidth="1dp" />

</LinearLayout>
