<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- =========================================================
         ZEALTH BRAND PALETTE (Corporate / Medical / Glass UI)
         + iOS-like System Palette for iOS-styled screens
         ========================================================= -->

    <!-- =========================
         State colors (defined first so aliases always resolve)
         ========================= -->
    <color name="zealth_success">#1E8E5A</color>
    <color name="zealth_warning">#F59E0B</color>
    <color name="zealth_error">#D32F2F</color>
    <color name="zealth_info">#0EA5E9</color>

    <!-- =========================
         Backward-compatible aliases
         ========================= -->
    <color name="warning_orange">@color/zealth_warning</color>
    <color name="error_red">@color/zealth_error</color>
    <color name="success_green">@color/zealth_success</color>
    <color name="info_cyan">@color/zealth_info</color>

    <!-- =========================
         Primary brand colors (teal-blue)
         ========================= -->
    <color name="zealth_primary">#0B5FA5</color>
    <color name="zealth_primary_variant">#084B83</color>
    <color name="zealth_on_primary">#FFFFFF</color>

    <!-- Opacity variants (AARRGGBB) -->
    <color name="zealth_primary_88">#E00B5FA5</color>   <!-- 88% -->
    <color name="zealth_primary_22">#380B5FA5</color>   <!-- 22% -->

    <!-- =========================
         Secondary (supporting accent)
         ========================= -->
    <color name="zealth_secondary">#0EA5E9</color>
