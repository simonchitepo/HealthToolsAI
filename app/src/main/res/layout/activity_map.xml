<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <org.osmdroid.views.MapView
        android:id="@+id/map"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <View
        android:id="@+id/mapDimOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#14000000"
        android:clickable="false"
        android:focusable="false"
        android:importantForAccessibility="no" />

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent">

        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/topAppBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:fitsSystemWindows="true"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            app:elevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/searchCard"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="10dp"
                    app:cardBackgroundColor="#33FFFFFF"
                    app:strokeWidth="1dp"
                    app:strokeColor="#33FFFFFF">

                    <!-- Back + Search in one row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageButton
                            android:id="@+id/btnBack"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:layout_marginStart="6dp"
                            android:background="@android:color/transparent"
                            android:padding="10dp"
                            android:src="@drawable/ic_back_medical"
                            android:contentDescription="Back"
                            android:tint="@android:color/white" />

                        <androidx.appcompat.widget.SearchView
                            android:id="@+id/searchView"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            app:queryHint="Search country or ISO code"
                            app:iconifiedByDefault="false"
                            app:queryBackground="@android:color/transparent" />
                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Disease Chips: horizontal scrollable -->
                <HorizontalScrollView
                    android:id="@+id/diseaseScroll"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:scrollbars="none"
                    android:overScrollMode="never">

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/diseaseChipGroup"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:singleLine="true"
                        app:singleSelection="true"
                        app:selectionRequired="true"
                        app:chipSpacingHorizontal="10dp" />
                </HorizontalScrollView>

            </LinearLayout>
        </com.google.android.material.appbar.AppBarLayout>

        <!-- Facilities FAB -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabFacilities"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="18dp"
            android:layout_marginBottom="220dp"
            app:srcCompat="@android:drawable/ic_dialog_map"
            app:backgroundTint="#33FFFFFF"
            app:tint="@android:color/white"
            app:elevation="0dp" />
        <!-- Zoom controls (LEFT side) -->
        <LinearLayout
            android:id="@+id/zoomControls"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:layout_marginStart="18dp"
            android:layout_marginBottom="190dp"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btnZoomIn"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@android:color/transparent"
                android:padding="0dp"
                android:scaleType="center"
                android:src="@android:drawable/ic_input_add"
                android:tint="@android:color/white"
                android:contentDescription="Zoom in" />

            <ImageButton
                android:id="@+id/btnZoomOut"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginTop="12dp"
                android:background="@android:color/transparent"
                android:padding="0dp"
                android:scaleType="center"
                android:src="@drawable/ic_remove"
                android:tint="@android:color/white"
                android:contentDescription="Zoom out" />

        </LinearLayout>





        <!-- Scrim shown when risk info card is open -->
        <View
            android:id="@+id/riskInfoScrim"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#26000000"
            android:visibility="gone"
            />

        <!-- Bottom popup panel (smaller) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/bottomPanelCard"
            android:layout_width="360dp"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="14dp"
            app:cardBackgroundColor="#33FFFFFF"
            app:strokeWidth="1dp"
            app:strokeColor="#22FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <View
                    android:layout_width="42dp"
                    android:layout_height="4dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="10dp"
                    android:background="#33FFFFFF" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvYearLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Year: 2024"
                        android:textColor="@android:color/white"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvPredictionBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="#2A00C853"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:text="LIVE"
                        android:textColor="@android:color/white"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:visibility="visible" />
                </LinearLayout>

                <com.google.android.material.slider.Slider
                    android:id="@+id/yearSlider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/tvDataMeta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text=""
                    android:textColor="#DFFFFFFF"
                    android:textSize="12sp" />

                <!-- Compact legend -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:layout_marginEnd="6dp"
                        android:background="#E53935" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Critical"
                        android:textColor="#EFFFFFFF"
                        android:textSize="12sp" />

                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:layout_marginEnd="6dp"
                        android:background="#FFA000" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Moderate"
                        android:textColor="#EFFFFFFF"
                        android:textSize="12sp" />

                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:layout_marginEnd="6dp"
                        android:background="#2E7D32" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Low"
                        android:textColor="#EFFFFFFF"
                        android:textSize="12sp" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Popup info card aligned with popup panel -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/riskInfoCard"
            android:layout_width="360dp"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="300dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="18dp"
            app:cardBackgroundColor="#33FFFFFF"
            app:strokeWidth="1dp"
            app:strokeColor="#22FFFFFF"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvInfoTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Nigeria"
                        android:textColor="@android:color/white"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvInfoBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="#CCB71C1C"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:text="CRITICAL"
                        android:textColor="@android:color/white"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btnInfoClose"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="8dp"
                        android:text="  ✕"
                        android:textColor="#EFFFFFFF"
                        android:textSize="16sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvInfoSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Disease • year"
                    android:textColor="#DFFFFFFF"
                    android:textSize="12sp" />

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fillViewport="true"
                    android:maxHeight="240dp"
                    android:overScrollMode="never">

                    <TextView
                        android:id="@+id/tvInfoBody"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:lineSpacingExtra="3dp"
                        android:text="Details"
                        android:textColor="#EFFFFFFF"
                        android:textSize="13sp" />
                </ScrollView>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

</FrameLayout>
